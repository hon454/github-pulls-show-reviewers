{
  "name": "github-pulls-show-reviewers",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "Chrome extension focused on showing reviewers directly in GitHub pull request lists.",
  "scripts": {
    "dev": "wxt",
    "build": "wxt build --browser chrome",
    "zip": "wxt zip --browser chrome",
    "prepare": "wxt prepare",
    "typecheck": "tsc --noEmit",
    "lint": "eslint .",
    "format": "prettier --write .",
    "test": "vitest run",
    "test:e2e": "playwright test"
  },
  "dependencies": {
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "zod": "^4.1.12"
  },
  "devDependencies": {
    "@playwright/test": "^1.55.0",
    "@types/react": "^19.0.12",
    "@types/react-dom": "^19.0.8",
    "eslint": "^9.38.0",
    "eslint-config-prettier": "^10.1.8",
    "prettier": "^3.6.2",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.46.1",
    "vitest": "^3.2.4",
    "wxt": "^0.20.7"
  },
  "packageManager": "pnpm@10.18.3"
}
